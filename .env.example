# Copy this file to .env and adjust values for your environment.
# .env is loaded by docker-compose and by the backend (pydantic-settings).

# --- Security ---------------------------------------------------------
# Required. Clients must send this value in the "X-API-Key" header.
# Also passed to the frontend service (docker-compose.yml) - its nginx
# attaches this header to proxied "/api/" requests, see docs/security.md.
API_KEY=change-me-to-a-long-random-secret

# Set to "false" in production to disable the interactive OpenAPI docs
# (/docs, /redoc, /openapi.json). They are only protected by the API key
# while enabled.
DOCS_ENABLED=true

# --- Printer (V330M, ESC/POS over network) -----------------------------
PRINTER_HOST=192.168.1.50
PRINTER_PORT=9100
# Socket connect/read timeout in seconds
PRINTER_TIMEOUT=5
# Send a paper cut command (GS V) after each job
PRINTER_CUT_AFTER_PRINT=true
# Number of blank lines fed after the content (before cut)
PRINTER_FEED_LINES=3

# --- Print layout -------------------------------------------------------
# Characters per line for ESC/POS Font A on 80mm paper
PRINTER_WIDTH_CHARS=48
# Pixel width of the printable area, used for preview PNGs and icon sizing
PRINTER_WIDTH_PX=576

# --- Storage -------------------------------------------------------------
# SQLite database file (mounted volume in docker-compose)
DB_PATH=/data/app.db
# Directory containing template YAML files (mounted volume)
TEMPLATES_DIR=/app/config/templates
# Directory containing preset YAML files (mounted volume) - see
# Standarddruckobjekte section below.
PRESETS_DIR=/app/config/presets
# Directory for log files (mounted volume)
LOG_DIR=/app/logs
LOG_LEVEL=INFO

# --- Icons (Font Awesome) ------------------------------------------------
# Directory containing a Font Awesome Free webfont (e.g. fa-solid-900.ttf)
# and an icon-name -> unicode codepoint JSON map. See
# backend/assets/fontawesome/README.md for details. If missing, icons
# degrade gracefully to a placeholder.
FONTAWESOME_FONT_PATH=/app/assets/fontawesome/fa-solid-900.ttf
FONTAWESOME_MAP_PATH=/app/assets/fontawesome/icon-map.json

# Optional monospace TTF for the /api/preview PNG (e.g. a path to
# DejaVuSansMono.ttf). If unset, Pillow's bundled default font is used.
# PREVIEW_FONT_PATH=/app/assets/fonts/DejaVuSansMono.ttf

# --- Queue / retry behaviour ----------------------------------------------
# Base delay before the first retry of a failed job (seconds)
RETRY_BASE_DELAY_SECONDS=5
# Maximum delay between retries (seconds), exponential backoff is capped here
RETRY_MAX_DELAY_SECONDS=300
# Worker idle poll interval when the queue is empty (seconds)
QUEUE_POLL_INTERVAL_SECONDS=1

# --- Standarddruckobjekte (Presets) ---------------------------------------
# Konfiguration fuer die Inhalts-Skripte der Standarddruckobjekte (siehe
# backend/config/presets/ und docs/presets.md). Alle Variablen in diesem
# Abschnitt sind optional - die zugehoerigen Presets liefern ohne
# Konfiguration einen klaren Fehler statt eines Druckauftrags.

# Mealie (Einkaufsliste) - Basis-URL und API-Token (Mealie -> Benutzerprofil
# -> "API-Tokens"). MEALIE_SHOPPING_LIST_ID ist optional; ohne Angabe wird
# die erste vorhandene Einkaufsliste verwendet.
# MEALIE_BASE_URL=https://mealie.bondrucker-app.de
# MEALIE_API_TOKEN=
# MEALIE_SHOPPING_LIST_ID=

# Wettervorhersage (HomeAssistant). Aktuelle Werte kommen von der Wetterstation,
# Vorhersage und Bedingung aus weather.openweathermap.
# HOMEASSISTANT_URL=https://homeassistant.bondrucker-app.de
# HOMEASSISTANT_TOKEN=<Langzeit-Zugriffstoken aus HA-Benutzerprofil>
# Entity-ID des Steckdosen-Switches fuer den Drucker (default: switch.plug_016)
# HOMEASSISTANT_PRINTER_PLUG=switch.plug_016
WEATHER_LOCATION_NAME=Hamburg

# Super Productivity (heutige Aufgaben) - WebDAV-Sync-Zugangsdaten, wie in
# den Sync-Einstellungen von Super Productivity konfiguriert.
# SP_WEBDAV_URL=https://webdav.bondrucker-app.de/remote.php/dav/files/user
# SP_WEBDAV_USERNAME=
# SP_WEBDAV_PASSWORD=
# SP_SYNC_PATH=super-productivity

# Jagdtag (heute) - Zugangsdaten fuer die PostgreSQL-Tabelle "jagdzeiten"
# (Spalten title, wild_haarwild, wild_federwild). JAGD_DB_NAME/_USER/_PASSWORD
# sind erforderlich; ohne diese liefert das Preset einen 502 PresetScriptError
# statt eines Druckauftrags.
# JAGD_DB_HOST=sql01.bondrucker-app.de
# JAGD_DB_PORT=5123
# JAGD_DB_NAME=
# JAGD_DB_USER=
# JAGD_DB_PASSWORD=

# --- CORS (only relevant if frontend is served from a different origin) ----
CORS_ORIGINS=https://bondrucker.bondrucker-app.de

# --- Frontend --------------------------------------------------------------
# Base URL the frontend container's nginx proxies "/api" and "/health" to
BONDRUCKER_BACKEND_URL=backend-bondrucker.bondrucker-app.de
BONDRUCKER_FRONTEND_URL=bondrucker.bondrucker-app.de