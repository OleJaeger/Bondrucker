# Copy this file to .env for local development with "npm run dev".
#
# Only used by vite.config.ts to authenticate the dev proxy against the
# backend (mirrors what the frontend's nginx does in production via
# nginx.conf.template). Never bundled into client code.

# Same value as the backend's API_KEY (see ../.env.example).
API_KEY=change-me-to-a-long-random-secret
